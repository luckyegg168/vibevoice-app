<Page x:Class="VibeVoice.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="580" d:DesignWidth="680"
      Title="設定">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32" MaxWidth="560" HorizontalAlignment="Center">

            <TextBlock Text="設定" FontSize="20" FontWeight="SemiBold"
                       Margin="0,0,0,24"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

            <!-- API Settings -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="辨識 API" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="API 端點" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                    <ui:TextBox Text="{Binding ApiEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="http://192.168.80.60:8000"
                                Margin="0,0,0,12"/>

                    <TextBlock Text="逾時時間 (秒)" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                    <ui:NumberBox Value="{Binding ApiTimeout}"
                                  Minimum="1" Maximum="120" SpinButtonPlacementMode="Compact"
                                  Margin="0,0,0,0"/>
                </StackPanel>
            </ui:Card>

            <!-- Hotkey -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="快捷鍵" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="全域錄音快捷鍵 (例: Ctrl+Alt+V)" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                    <ui:TextBox Text="{Binding GlobalHotkey, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Ctrl+Alt+V"/>
                </StackPanel>
            </ui:Card>

            <!-- Behavior -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="行為設定" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <ui:ToggleSwitch Content="最小化至系統匣"
                                     IsChecked="{Binding MinimizeToTray}"
                                     Margin="0,0,0,8"/>

                    <ui:ToggleSwitch Content="啟動時最小化"
                                     IsChecked="{Binding StartMinimized}"
                                     Margin="0,0,0,8"/>

                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="輸入延遲 (ms，每個字符間隔)" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                        <ui:NumberBox Value="{Binding TypeDelayMs}"
                                      Minimum="0" Maximum="100" SpinButtonPlacementMode="Compact"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Save Status -->
            <TextBlock Text="{Binding SaveStatusText}" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,8"
                       Foreground="#0F7B0F"/>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0" Content="重設為預設值"
                           Appearance="Secondary"
                           Command="{Binding ResetCommand}"
                           HorizontalAlignment="Left" Padding="16,8"/>
                <ui:Button Grid.Column="2" Content="儲存設定"
                           Appearance="Primary"
                           Command="{Binding SaveCommand}"
                           Padding="24,8"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
